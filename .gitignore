# ── User data — NEVER commit ────────────────────────────────────────────────
# Decision Profiles are personal data. Only the engine is published; profiles
# stay local on each user's machine.
*.dpf.json
*.report.md
*.kv
*.answers.json

# Keep the empty profiles/ folder shape, but never its contents.
skills/*/profiles/*
!skills/*/profiles/.gitkeep

# ── Python / OS cruft ───────────────────────────────────────────────────────
__pycache__/
*.pyc
.DS_Store
